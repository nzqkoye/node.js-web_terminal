"use strict";

const http = require("http");
const WebSocket = require("ws");
const pty = require("node-pty");
const os = require("os");
const fs = require("fs");

const PORT = 3000;
const HOST = "127.0.0.1";

// ==================== 1. 解析命令行参数 ====================
let authEnabled = false;
let authUser = "";
let authPass = "";

const args = process.argv;
const cIndex = args.indexOf("-c");

if (cIndex !== -1 && args[cIndex + 1]) {
    const credentials = args[cIndex + 1].split("/");
    if (credentials.length === 2 && credentials[0] && credentials[1]) {
        authUser = credentials[0];
        authPass = credentials[1];
        authEnabled = true;
    } else {
        console.error("[ERROR] 参数格式错误！正确格式为: -c 用户名/密码 (例如: -c admin/123456)");
        process.exit(1);
    }
}

// ==================== 2. 身份验证拦截器 ====================
function authenticate(req) {
    if (!authEnabled) return true; // 未启用认证，直接放行

    const authHeader = req.headers["authorization"];
    if (!authHeader) return false;

    // 解析 Basic Auth 请求头 (格式: Basic base64(user:pass))
    const match = authHeader.match(/^Basic\s+(.*)$/i);
    if (!match) return false;

    const credentials = Buffer.from(match[1], "base64").toString("ascii").split(":");
    return credentials[0] === authUser && credentials[1] === authPass;
}

// ==================== 3. 获取 Bash 路径 ====================
function getBashShell() {
    const platform = os.platform();
    if (platform !== "win32") return "bash";

    const gitBashPaths = [
        "C:\\Program Files\\Git\\bin\\bash.exe",
        "C:\\Program Files (x86)\\Git\\bin\\bash.exe"
    ];
    for (const binPath of gitBashPaths) {
        if (fs.existsSync(binPath)) return binPath;
    }
    return fs.existsSync("C:\\Windows\\System32\\bash.exe") ? "bash.exe" : "powershell.exe";
}

// ==================== 4. 前端 HTML 模板 ====================
const htmlContent = `<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <title>Web Terminal (Bash)</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/xterm@5.3.0/css/xterm.css" />
    <script src="https://cdn.jsdelivr.net/npm/xterm@5.3.0/lib/xterm.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/xterm-addon-fit@0.8.0/lib/xterm-addon-fit.js"></script>
    <style>
        body { margin: 0; background: #1e1e1e; overflow: hidden; }
        #terminal { width: 100vw; height: 100vh; }
    </style>
</head>
<body>
    <div id="terminal"></div>
    <script>
        const term = new Terminal({
            cursorBlink: true,
            fontFamily: 'Courier New, monospace',
            fontSize: 14,
            theme: { background: '#1e1e1e' }
        });
        const fitAddon = new FitAddon.FitAddon();
        term.loadAddon(fitAddon);
        term.open(document.getElementById('terminal'));
        fitAddon.fit();

        const protocol = window.location.protocol === 'https:' ? 'wss://' : 'ws://';
        const socket = new WebSocket(protocol + window.location.host);

        socket.onopen = () => {
            sendResize();
            term.onData(data => socket.send(JSON.stringify({ type: 'input', data })));
        };

        socket.onmessage = event => term.write(event.data);

        function sendResize() {
            fitAddon.fit();
            if (socket.readyState === WebSocket.OPEN) {
                socket.send(JSON.stringify({
                    type: 'resize',
                    cols: term.cols,
                    rows: term.rows
                }));
            }
        }

        window.addEventListener('resize', sendResize);
        socket.onclose = () => term.write('\\r\\n[Bash 连接已断开]\\r\\n');
    </script>
</body>
</html>`;

// ==================== 5. HTTP 服务 (带 Basic Auth 拦截) ====================
const server = http.createServer((req, res) => {
    if (!authenticate(req)) {
        res.writeHead(401, {
            "WWW-Authenticate": 'Basic realm="Secure Web Terminal"',
            "Content-Type": "text/plain; charset=utf-8"
        });
        return res.end("需要身份认证。");
    }

    res.writeHead(200, { "Content-Type": "text/html; charset=utf-8" });
    res.end(htmlContent);
});

// ==================== 6. WebSocket 服务 (带连接安全验证) ====================
const wss = new WebSocket.Server({ server });

wss.on("connection", (ws, req) => {
    // 验证 WebSocket 连接是否合法
    if (!authenticate(req)) {
        ws.close(4001, "Unauthorized");
        return;
    }

    const shell = getBashShell();
    const ptyProcess = pty.spawn(shell, [], {
        name: "xterm-256color",
        cols: 80,
        rows: 24,
        cwd: os.homedir(),
        env: Object.assign({}, process.env, { TERM: "xterm-256color" })
    });

    ptyProcess.onData((data) => {
        if (ws.readyState === WebSocket.OPEN) {
            ws.send(data);
        }
    });

    ws.on("message", (message) => {
        try {
            const msg = JSON.parse(message.toString());
            if (msg.type === "input" && typeof msg.data === "string") {
                ptyProcess.write(msg.data);
            } else if (msg.type === "resize") {
                const cols = Math.max(1, parseInt(msg.cols, 10) || 80);
                const rows = Math.max(1, parseInt(msg.rows, 10) || 24);
                ptyProcess.resize(cols, rows);
            }
        } catch (e) {
            ptyProcess.write(message.toString());
        }
    });

    const cleanup = () => {
        try { ptyProcess.kill(); } catch (e) {}
    };

    ws.on("close", cleanup);
    ws.on("error", cleanup);
});

// ==================== 7. 启动服务 ====================
server.listen(PORT, HOST, () => {
    console.log(`================================================`);
    console.log(`  Web Terminal 运行在: http://${HOST}:${PORT}`);
    if (authEnabled) {
        console.log(`  [安全模式] 已启用身份验证。用户名: ${authUser}`);
    } else {
        console.log(`  [警告] 未启用身份验证！如需加密，请使用: node server.js -c 用户名/密码`);
    }
    console.log(`================================================`);
});
